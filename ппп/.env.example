# ываыва — переменные окружения
# Скопируйте в .env и заполните значения

APP_NAME=ываыва
APP_ENV=development
APP_DEBUG=true

PYTHON_VERSION=3.12

# Данные
DATA_DIR=data/
OUTPUT_DIR=outputs/
LOG_DIR=logs/
LOG_LEVEL=INFO

# API
# API_KEY=your-api-key-here
# API_SECRET=your-secret-here

# База данных (если используется)
# DATABASE_URL=sqlite:///data/db.sqlite3

# MLflow (если используется)
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=ываыва